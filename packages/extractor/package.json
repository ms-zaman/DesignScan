{
  "name": "@designscan/extractor",
  "version": "0.1.0",
  "description": "URL -> design tokens -> DESIGN.md. The extraction engine.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
