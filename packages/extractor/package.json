{
  "name": "@designscan/extractor",
  "version": "0.2.0",
  "description": "URL -> design tokens -> DESIGN.md. The extraction engine.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "design-tokens",
    "design.md",
    "css",
    "playwright",
    "extractor",
    "design-system"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ms-zaman/DesignScan.git",
    "directory": "packages/extractor"
  },
  "homepage": "https://github.com/ms-zaman/DesignScan/tree/main/packages/extractor#readme",
  "bugs": "https://github.com/ms-zaman/DesignScan/issues",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "designscan": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "extract": "tsx src/cli.ts",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "capture:fixtures": "tsx src/__fixtures__/capture.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  }
}
