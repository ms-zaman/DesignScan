{
  "name": "designscan",
  "version": "0.0.0",
  "description": "URL → design tokens → DESIGN.md. Monorepo for the DesignScan product.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "extract": "pnpm --filter @designscan/extractor exec tsx src/cli.ts",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:designmd": "for f in examples/*.DESIGN.md; do echo \"→ $f\"; design.md lint \"$f\"; done"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@google/design.md": "^0.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
